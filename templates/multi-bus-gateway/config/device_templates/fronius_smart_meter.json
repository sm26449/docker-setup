{
  "device_template": {
    "schema_version": 1,
    "id": "fronius_smart_meter",
    "name": "Fronius Smart Meter (SunSpec, via DataManager)",
    "vendor": "Fronius International GmbH",
    "model": "Smart Meter TS / 63A (SunSpec 203)",
    "version": "0.1.0-draft",
    "author": "pv-stack",
    "description": "Input map for the Fronius Smart Meter read over Modbus TCP via the Fronius DataManager (typically unit 240). SunSpec int+SF meter model 203, addresses are 0-based (SunSpec reg - 1). Names follow the Janitza canonical vocabulary so the EM24/Fronius output profiles work unchanged. NOTE: scale factors are placeholders (1.0) — read the *_SF registers from the live meter once and bake the per-register scale before trusting magnitudes.",
    "source_document": "SunSpec Alliance Modbus model 203; Fronius Datamanager Modbus TCP",
    "protocol": {
      "transports": [
        "tcp"
      ],
      "default_unit_id": 240,
      "functions": [
        3
      ],
      "byte_order": "big",
      "max_registers_per_read": 60
    },
    "poll_groups": {
      "realtime": {
        "interval": 1,
        "description": "Live power/voltage/current"
      },
      "normal": {
        "interval": 5,
        "description": "Standard measurements"
      },
      "slow": {
        "interval": 60,
        "description": "Energy counters"
      }
    },
    "categories": {
      "voltage_line_neutral": {
        "label": "Voltage L-N",
        "order": 1
      },
      "voltage_line_line": {
        "label": "Voltage L-L",
        "order": 2
      },
      "current_phase": {
        "label": "Current per phase",
        "order": 3
      },
      "current_sum": {
        "label": "Current total",
        "order": 4
      },
      "power_active": {
        "label": "Active power (W)",
        "order": 5
      },
      "power_reactive": {
        "label": "Reactive power (var)",
        "order": 6
      },
      "power_apparent": {
        "label": "Apparent power (VA)",
        "order": 7
      },
      "power_factor_pf": {
        "label": "Power factor",
        "order": 8
      },
      "energy_active": {
        "label": "Energy (Wh)",
        "order": 9
      },
      "frequency": {
        "label": "Frequency",
        "order": 10
      },
      "config_other": {
        "label": "Scale factors / config",
        "order": 11
      }
    },
    "registers": [
      {
        "address": 40072,
        "name": "_ILN[0]",
        "label": "Phase A current",
        "unit": "A",
        "data_type": "int16",
        "access": "RD",
        "category": "current_phase",
        "description": "Phase A current"
      },
      {
        "address": 40073,
        "name": "_ILN[1]",
        "label": "Phase B current",
        "unit": "A",
        "data_type": "int16",
        "access": "RD",
        "category": "current_phase",
        "description": "Phase B current"
      },
      {
        "address": 40074,
        "name": "_ILN[2]",
        "label": "Phase C current",
        "unit": "A",
        "data_type": "int16",
        "access": "RD",
        "category": "current_phase",
        "description": "Phase C current"
      },
      {
        "address": 40071,
        "name": "AI_SUM",
        "label": "Total AC current",
        "unit": "A",
        "data_type": "int16",
        "access": "RD",
        "category": "current_sum",
        "description": "Total AC current"
      },
      {
        "address": 40075,
        "name": "A_SF",
        "label": "Current scale factor (SunSpec)",
        "unit": "",
        "data_type": "int16",
        "access": "RD",
        "category": "config_other",
        "description": "Current scale factor (SunSpec)"
      },
      {
        "address": 40077,
        "name": "_G_ULN[0]",
        "label": "Phase A voltage L-N",
        "unit": "V",
        "data_type": "int16",
        "access": "RD",
        "category": "voltage_line_neutral",
        "description": "Phase A voltage L-N"
      },
