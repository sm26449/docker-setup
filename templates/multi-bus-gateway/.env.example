# Janitza UMG 512-PRO Monitor - Environment Configuration
# Copy this file to .env and modify as needed
#
# Modbus / MQTT / InfluxDB are normally configured from the UI (Config -> Settings),
# persisted to config/config.yaml and applied without a restart — you do NOT need to
# set them here. The variables below are OPTIONAL: uncomment them only to pre-seed a
# fresh deploy. A value set here OVERRIDES the UI/config.yaml on every restart, and the
# UI shows that field as "locked by environment". (Also uncomment the matching lines in
# docker-compose.yml.) Variable names are UNPREFIXED (MODBUS_HOST, not JANITZA_MODBUS_HOST).

# ======================
# Modbus Configuration (optional — usually set from the UI)
# ======================
# MODBUS_HOST=192.168.1.100
# MODBUS_PORT=502
# MODBUS_UNIT_ID=1

# ======================
# MQTT Configuration (optional — usually set from the UI)
# ======================
# MQTT_ENABLED=true
# MQTT_BROKER=mqtt-broker
# MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_PREFIX=janitza/umg512
# MQTT_PUBLISH_MODE=changed

# ======================
# InfluxDB Configuration (optional — usually set from the UI)
# ======================
# INFLUXDB_ENABLED=false
# INFLUXDB_URL=http://influxdb:8086
# INFLUXDB_TOKEN=
# INFLUXDB_ORG=
# INFLUXDB_BUCKET=janitza
# INFLUXDB_PUBLISH_MODE=changed

# ======================
# UI Configuration
# ======================
UI_PORT=8080

# ======================
# Security (optional)
# ======================
# If set, every state-changing API request (POST/PUT/PATCH/DELETE) must carry an
# X-API-Key header matching this value; the Web UI prompts for it once and
# remembers it. Read-only telemetry (GET) and the on-demand register queries
# stay open. Leave empty for an open, trusted-LAN appliance (default).
API_KEY=

# ======================
# Virtual Meters (optional)
# ======================
# Port range published for virtual Modbus meters (reachable on the LAN).
# Pick instance ports inside this range; widen the end if you need more.
# Port 502 (standard Modbus, e.g. Fronius DataManager) is published separately
# in docker-compose.yml. See docs/VIRTUAL-METER.md.
VMETER_PORT_START=1502
VMETER_PORT_END=1512

# ======================
# Optional InfluxDB Container
# (only used with --profile influxdb)
# ======================
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=change-me-secure-password
DOCKER_INFLUXDB_INIT_ORG=janitza
DOCKER_INFLUXDB_INIT_BUCKET=janitza
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=change-me-secure-token

# ======================
# Optional Grafana Container
# (only used with --profile grafana)
# ======================
GF_SECURITY_ADMIN_PASSWORD=change-me-secure-password
